# ─────────────────────────────────────────────────────────────
# Routiq – Landing Page environment variables
# Copy this file to .env and fill in your values.
# Never commit the real .env file to Git.
# ─────────────────────────────────────────────────────────────

# Sanity project credentials
# Get these from https://sanity.io/manage → your project → Settings → API
SANITY_PROJECT_ID=YOUR_PROJECT_ID
SANITY_DATASET=production

# The read-only API token allows the frontend to fetch published content.
# Create one at: Sanity.io → Project → Settings → API → Tokens → Add new token (Viewer role)
SANITY_READ_TOKEN=YOUR_VIEWER_TOKEN
